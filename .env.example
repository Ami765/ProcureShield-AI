# ─────────────────────────────────────────────────────────────
#  ProcureShield AI — Environment Configuration
#  Copy this file to .env and fill in your Gemini API key
# ─────────────────────────────────────────────────────────────

# Get your FREE key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Model options: gemini-1.5-flash (fast/free) or gemini-1.5-pro (smarter)
GEMINI_MODEL=gemini-1.5-flash
